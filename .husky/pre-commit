#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."

echo "📦 Running lint-staged for staged files..."
npx lint-staged
if [ $? -ne 0 ]; then
  echo "❌ lint-staged failed. Please fix the issues before committing."
  exit 1
fi

echo "✅ Pre-commit checks passed."
exit 0
