{
  "name": "crypto-vault-pro",
  "version": "1.0.0",
  "description": "A frontend system design case study: resilient, offline‑first crypto portfolio tracker built with Angular, domain‑driven design, and production‑grade engineering patterns.",
  "keywords": [
    "angular",
    "cryptocurrency",
    "portfolio",
    "typescript",
    "pwa",
    "offline-first",
    "resilience"
  ],
  "author": "Jahanzaib Jameel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JahanzaibJameel/CryptoVault-Pro.git"
  },
  "bugs": {
    "url": "https://github.com/JahanzaibJameel/CryptoVault-Pro/issues"
  },
  "homepage": "https://crypto-vault-pro.netlify.app",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:ssl": "ng serve --ssl",
    "build": "ng build",
    "build:production": "ng build --configuration production",
    "build:analyze": "ng build --stats-json && npx webpack-bundle-analyzer dist/crypto-vault-pro/stats.json",
    "watch": "ng build --watch",
    "test": "jest --config jest.config.js",
    "test:unit": "jest --config jest.config.js",
    "test:integration": "jest --testPathPattern=src/**/*.integration.spec.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --watchAll=false --coverage --ci",
    "lighthouse": "lhci autorun",
    "lighthouse:ci": "lhci autorun --upload.target=temporary-public-storage",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "format": "prettier --write \"src/**/*.{ts,html,scss,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,css,json}\"",
    "type-check": "tsc --noEmit",
    "analyze:bundle": "npx webpack-bundle-analyzer dist/crypto-vault-pro/stats.json",
    "clean": "rimraf dist coverage .angular/cache",
    "validate": "npm run type-check && npm run lint && npm run test:ci",
    "precommit": "lint-staged",
    "prepare": "husky install"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/cdk": "^21.2.10",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/localize": "^21.2.12",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/service-worker": "^21.2.12",
    "@angular/ssr": "^21.2.0",
    "@sentry/angular": "^10.52.0",
    "@sentry/tracing": "^7.120.4",
    "idb": "^8.0.3",
    "lightweight-charts": "^5.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.16.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.10",
    "@angular-eslint/builder": "21.4.0",
    "@angular-eslint/eslint-plugin": "21.4.0",
    "@angular-eslint/eslint-plugin-template": "21.4.0",
    "@angular-eslint/schematics": "21.4.0",
    "@angular-eslint/template-parser": "21.4.0",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.0",
    "@playwright/test": "^1.40.0",
    "@testing-library/angular": "^19.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jasmine": "~5.1.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "angular-eslint": "^21.4.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^8.0.3",
    "jasmine-core": "~5.1.0",
    "jest": "^30.4.1",
    "jest-environment-jsdom": "^30.4.1",
    "jest-extended": "^7.0.0",
    "jest-image-snapshot": "^6.5.2",
    "jest-jasmine2": "^30.4.1",
    "jest-preset-angular": "^16.1.5",
    "lint-staged": "^15.2.0",
    "msw": "^2.14.5",
    "prettier": "^3.8.1",
    "rimraf": "^5.0.5",
    "ts-node": "~10.9.0",
    "typescript": "~5.9.2"
  },
  "browserslist": [
    "Chrome >= 120",
    "Firefox >= 120",
    "Safari >= 17",
    "Edge >= 120"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "src/**/*.{ts,html,scss,css,json}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
